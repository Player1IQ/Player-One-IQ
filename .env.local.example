# Get these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public app URL used in server-sent emails (optional locally; inferred from request headers)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Team invite emails via Resend (https://resend.com)
# For testing, use onboarding@resend.dev as INVITE_EMAIL_FROM
RESEND_API_KEY=re_xxxxxxxx
INVITE_EMAIL_FROM=Player One IQ <onboarding@resend.dev>

