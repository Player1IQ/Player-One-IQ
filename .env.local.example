# Get these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — required for scheduled platform revenue sync (server only, never expose to client)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public app URL used in server-sent emails (optional locally; inferred from request headers)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Team invite emails via Resend (https://resend.com)
# For testing, use onboarding@resend.dev as INVITE_EMAIL_FROM
RESEND_API_KEY=re_xxxxxxxx
INVITE_EMAIL_FROM=Player One IQ <onboarding@resend.dev>

# Automatic platform income sync (OAuth) — disabled until setup is complete
PLATFORM_OAUTH_ENABLED=false
# Set PLATFORM_OAUTH_ENABLED=true after adding credentials below
# YouTube: Google Cloud Console → APIs → YouTube Analytics API + YouTube Data API v3
# Redirect URI: http://localhost:3000/api/platform-oauth/youtube/callback
# Twitch: Developer Console → OAuth Redirect URL:
# http://localhost:3000/api/platform-oauth/twitch/callback
# Instagram: Meta Developer → Instagram API with Instagram Login
# http://localhost:3000/api/platform-oauth/instagram/callback
# TikTok: TikTok for Developers → Login Kit
# http://localhost:3000/api/platform-oauth/tiktok/callback
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
# INSTAGRAM_CLIENT_ID=
# INSTAGRAM_CLIENT_SECRET=
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# PLATFORM_OAUTH_STATE_SECRET=generate-a-long-random-string

# Scheduled OAuth revenue sync (daily at 6:00 UTC when deployed to Vercel)
# CRON_SECRET=generate-a-long-random-string
# Requires SUPABASE_SERVICE_ROLE_KEY above. Vercel sends Authorization automatically.
# Local test: curl -H "Authorization: Bearer <CRON_SECRET>" http://localhost:3000/api/cron/sync-platform-revenue

# AI assistants — optional platform fallback; workspaces can connect their own key in Settings
# AI_ENABLED=true
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# Encrypt org BYOK keys (generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
# AI_CREDENTIALS_ENCRYPTION_KEY=

# Agency Pro external API — optional pepper for API key hashing (server only)
# API_KEY_PEPPER=generate-a-long-random-string

# Stripe billing (https://dashboard.stripe.com/test/apikeys)
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...  (from Stripe CLI or Dashboard → Webhooks)

# --- E2E tests (optional; Playwright skips authenticated suites when unset) ---
# Start dev server first: npm run dev
# PLAYWRIGHT_BASE_URL=http://localhost:3000
# E2E_PORTAL_EMAIL=portal-user@example.com
# E2E_PORTAL_PASSWORD=your-portal-password
# E2E_STAFF_EMAIL=staff-user@example.com
# E2E_STAFF_PASSWORD=your-staff-password

# --- Vercel deploy ---
# See .env.vercel.example for the full production variable list.
# Run: npm run verify:deploy
# Smoke test after deploy: GET https://your-app.vercel.app/api/health
