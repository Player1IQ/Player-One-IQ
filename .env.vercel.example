# Copy each variable into Vercel → Project → Settings → Environment Variables
# Apply to Production (and Preview if you want OAuth on preview deployments)

# --- Required ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_URL=https://player-one-iq.vercel.app
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CRON_SECRET=generate-a-long-random-string
PLATFORM_OAUTH_STATE_SECRET=generate-a-long-random-string

# --- Email (team invites) ---
RESEND_API_KEY=re_xxxxxxxx
INVITE_EMAIL_FROM=Player One IQ <onboarding@resend.dev>

# --- Platform OAuth ---
PLATFORM_OAUTH_ENABLED=true
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# INSTAGRAM_CLIENT_ID=
# INSTAGRAM_CLIENT_SECRET=
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=

# --- AI ---
# Platform fallback (optional when workspaces use BYOK in Settings)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Required to save workspace API keys
AI_CREDENTIALS_ENCRYPTION_KEY=

# Optional: extra secret mixed into Agency Pro API key hashes (server only)
# API_KEY_PEPPER=generate-a-long-random-string

# --- Stripe (test mode keys until go-live) ---
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Webhook endpoint: https://player-one-iq.vercel.app/api/billing/webhook
# Events: checkout.session.completed, customer.subscription.*

# --- After first deploy: register these redirect URLs ---
# YouTube (Google Cloud):  https://player-one-iq.vercel.app/api/platform-oauth/youtube/callback
# Twitch:                  https://player-one-iq.vercel.app/api/platform-oauth/twitch/callback
# Instagram (Meta):        https://player-one-iq.vercel.app/api/platform-oauth/instagram/callback
# TikTok:                  https://player-one-iq.vercel.app/api/platform-oauth/tiktok/callback
#
# Supabase → Authentication → URL configuration:
#   Site URL:     https://player-one-iq.vercel.app
#   Redirect URLs: https://player-one-iq.vercel.app/auth/callback
